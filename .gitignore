# =============================================================================
# Terraform
# =============================================================================

# Local .terraform directories (provider plugins, modules cache)
**/.terraform/

# Terraform state files (may contain secrets)
*.tfstate
*.tfstate.backup

# Terraform lock file (optional: commit if you want reproducible provider versions)
# .terraform.lock.hcl

# Terraform variable files that may contain sensitive values
*.tfvars
*.tfvars.json

# Terraform plan output files
*.tfplan
*.plan

# Terraform crash logs
crash.log
crash.*.log

# Override files (used for local overrides, not meant to be shared)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# =============================================================================
# CloudFormation
# =============================================================================

# Packaged/synthesized templates generated by `aws cloudformation package`
packaged-*.yaml
packaged-*.yml
packaged-*.template

# SAM build artifacts
.aws-sam/

# =============================================================================
# AWS credentials & config (never commit these)
# =============================================================================
.aws/credentials
.aws/config

# =============================================================================
# macOS
# =============================================================================
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db

# =============================================================================
# Editor & IDE
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~

# =============================================================================
# Logs & temp files
# =============================================================================
*.log
*.tmp
*.bak
