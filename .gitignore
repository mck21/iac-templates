# =============================================================================
# Terraform
# =============================================================================

# Local .terraform directories (provider plugins, modules cache)
**/.terraform/

# Terraform state files (may contain secrets)
*.tfstate
*.tfstate.backup

# Terraform lock file (uncomment if you want to version lock files)
.terraform.lock.hcl

# Terraform variable files that may contain sensitive values
*.tfvars
*.tfvars.json
*.auto.tfvars   # optional explicit rule

# Terraform plan output files
*.tfplan
*.plan

# Terraform crash logs
crash.log
crash.*.log

# Override files (local overrides, not meant to be shared)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# User‑specific Terraform config
.terraformrc
.terraform.d/

# =============================================================================
# CloudFormation / SAM
# =============================================================================

# Packaged/synthesized templates generated by `aws cloudformation package`
packaged-*.yaml
packaged-*.yml
packaged-*.template

# SAM build artifacts
.aws-sam/

# =============================================================================
# AWS credentials & config (never commit)
# =============================================================================
.aws/credentials
.aws/config

# =============================================================================
# macOS
# =============================================================================
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db

# =============================================================================
# Editor & IDE
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~

# =============================================================================
# Logs & temporary files
# =============================================================================
*.log
*.tmp
*.bak

# =============================================================================
# Build / distribution artifacts (if used)
# =============================================================================
build/
dist/
out/
